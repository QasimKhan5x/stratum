# QwenCloud / DashScope — the default LLM provider this repo ships with.
DASHSCOPE_API_KEY=

# --- Optional: point at a different OpenAI-compatible provider instead ---
# Every model call except scene illustration (backend/agents/illustrator.py,
# which needs DashScope's native image SDK) goes through the standard
# `openai` SDK, so any OpenAI-compatible endpoint works by overriding these:
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=
# LLM_MODEL_SEED=gpt-4o
# LLM_MODEL_ARBITER=gpt-4o
# LLM_MODEL_SPECIALIST=gpt-4o-mini
# LLM_MODEL_JUDGE=gpt-4o-mini
# LLM_MODEL_EMBEDDING=text-embedding-3-small

# --- Optional: local self-host database path (default: ./stratum.db) ---
# STRATUM_DB_PATH=./stratum.db

# --- Optional: Alibaba Cloud (only needed for the real cloud deployment;
# without these, runs persist to the local SQLite file above instead) ---
ALIBABA_CLOUD_ACCESS_KEY_ID=
ALIBABA_CLOUD_ACCESS_KEY_SECRET=
ALIBABA_CLOUD_REGION=ap-southeast-1
TABLESTORE_INSTANCE_NAME=
TABLESTORE_ENDPOINT=
OSS_BUCKET=
OSS_ENDPOINT=
